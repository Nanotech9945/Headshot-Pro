{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Profile last update time" }
      },
      "required": ["uid", "email"]
    },
    "Headshot": {
      "title": "Headshot",
      "description": "Generated headshot record",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the headshot" },
        "image": { "type": "string", "description": "Base64 or URL of the generated headshot" },
        "style": { "type": "string", "description": "ID of the selected style" },
        "filters": { "type": "object", "description": "Applied image filters" },
        "upscaled": { "type": "boolean" },
        "enhanced": { "type": "boolean" },
        "aspectRatio": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Generation time" }
      },
      "required": ["userId", "image", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User document"
    },
    "/users/{userId}/headshots/{headshotId}": {
      "schema": "Headshot",
      "description": "User's generated headshots"
    }
  }
}

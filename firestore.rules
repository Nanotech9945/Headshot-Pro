rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.keys().hasAll(['uid', 'email']);
    }

    function isValidGeneration(data) {
      return data.userId == request.auth.uid &&
             data.image is string &&
             data.image.size() <= 2 * 1024 * 1024; // Limit size for Firestore docs
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'credits'])
      );

      match /generations/{generationId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidGeneration(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}

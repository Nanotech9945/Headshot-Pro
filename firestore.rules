rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email_verified == true && request.auth.token.email == "t19788994@gmail.com") ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isNotBlocked() {
      return isAdmin() || (
        !isSignedIn() || 
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != 'blocked'
      );
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) 
        && data.keys().size() <= 12
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (data.credits == null || (data.credits is number && data.credits >= 0))
        && (data.role == null || data.role in ['user', 'admin'])
        && (data.status == null || data.status in ['active', 'blocked'])
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidHeadshot(data) {
      return data.keys().hasAll(['userId', 'image', 'timestamp'])
        && data.keys().size() <= 12
        && data.userId == request.auth.uid
        && data.image is string && data.image.size() <= 2000000
        && data.timestamp == request.time;
    }

    // --- Collection Routes ---

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && (
        isAdmin() || (
          isNotBlocked() && 
          incoming().uid == userId &&
          incoming().email == existing().email &&
          incoming().createdAt == existing().createdAt &&
          incoming().updatedAt == request.time
        )
      );
    }

    match /users/{userId}/headshots/{headshotId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isNotBlocked() && isValidHeadshot(incoming());
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Allow admins to see all headshots across all users via collectionGroup
    match /{path=**}/headshots/{headshotId} {
      allow read, list: if isAdmin();
    }
  }
}
